# ============================================================
# Post-Discharge Patient Care Agent — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-me-to-random-string-in-production
JWT_SECRET_KEY=another-random-string-here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postdischarge

# IBM watsonx.ai
# Get from: https://us-south.ml.cloud.ibm.com → Developer access
WATSONX_API_KEY=your-ibm-cloud-api-key-here
WATSONX_PROJECT_ID=956f2ec4-dc14-4a45-8146-baa650cea97e
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# IBM watsonx Orchestrate
# Get from: https://au-syd.watson-orchestrate.cloud.ibm.com
ORCHESTRATE_AGENT_ID=2828b79e-8ed4-474a-bff4-b4c5d7d455c1
ORCHESTRATE_URL=https://au-syd.watson-orchestrate.cloud.ibm.com

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT=postdischarge-care-agent

# Escalation Thresholds
PAIN_ESCALATION_THRESHOLD=7
FEVER_ESCALATION_THRESHOLD=101.5

# Notifications (Twilio SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Notifications (SendGrid Email)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=care@postdischarge.health
